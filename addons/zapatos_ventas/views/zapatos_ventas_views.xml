<odoo>
    <record id="view_zapatos_venta_tree" model="ir.ui.view">
        <field name="name">zapatos.venta.list</field>
        <field name="model">zapatos.venta</field>
        <field name="arch" type="xml">
            <list string="Ventas de Zapatos">
                <field name="fecha_venta"/>
                <field name="cliente_id"/>
                <field name="zapato_id"/>
                <field name="cantidad"/>
                <field name="precio_unitario"/>
                <field name="total_venta" sum="Total General"/>
            </list>
        </field>
    </record>

    <record id="view_zapatos_venta_form" model="ir.ui.view">
        <field name="name">zapatos.venta.form</field>
        <field name="model">zapatos.venta</field>
        <field name="arch" type="xml">
            <form string="Registro de Venta">
                <sheet>
                    <group>
                        <group>
                            <field name="cliente_id"/>
                            <field name="zapato_id"/>
                            <field name="fecha_venta"/>
                        </group>
                        <group>
                            <field name="cantidad"/>
                            <field name="precio_unitario"/>
                            <field name="total_venta" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_zapatos_ventas" model="ir.actions.act_window">
        <field name="name">Ventas de Zapatos</field>
        <field name="res_model">zapatos.venta</field>
        <field name="view_mode">list,form</field> </record>

    <menuitem id="menu_zapatos_ventas_root" name="Ventas Zapatos" sequence="20"/>
    <menuitem id="menu_zapatos_ventas_registro" name="Control de Ventas" parent="menu_zapatos_ventas_root" action="action_zapatos_ventas" sequence="10"/>
</odoo>